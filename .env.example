# ── POSTGRESQL ───────────────────────────────────────────────
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=  # openssl rand -hex 32

# ── REDIS ────────────────────────────────────────────────────
REDIS_PASSWORD=  # openssl rand -hex 32

# ── GITEA ────────────────────────────────────────────────────
GITEA_SECRET_KEY=  # openssl rand -hex 32
GITEA_INTERNAL_TOKEN=  # gitea generate secret INTERNAL_TOKEN
GITEA_API_TOKEN=  # Create in Gitea UI > Settings > Applications

# ── CLAUDE (authentication for all agents) ───────────────────
CLAUDE_SETUP_TOKEN=clst_REPLACE_ME_WITH_REAL_TOKEN  # Run: claude setup-token

# ── PAPERCLIP ────────────────────────────────────────────────
PAPERCLIP_ADMIN_EMAIL=admin@paperclip.local
PAPERCLIP_ADMIN_PASSWORD=  # choose a strong password
PAPERCLIP_AUTH_SECRET=  # openssl rand -hex 32
PAPERCLIP_AGENT_JWT_SECRET=  # openssl rand -hex 32

# ── ANTHROPIC (optional — only if Mem0 uses Anthropic instead of Ollama)
# ANTHROPIC_API_KEY=sk-ant-...
