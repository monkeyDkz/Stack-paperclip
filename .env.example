# ── POSTGRESQL ───────────────────────────────────────────────
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=  # openssl rand -hex 32

# ── REDIS ────────────────────────────────────────────────────
REDIS_PASSWORD=  # openssl rand -hex 32

# ── GITEA ────────────────────────────────────────────────────
GITEA_SECRET_KEY=  # openssl rand -hex 32
GITEA_INTERNAL_TOKEN=  # gitea generate secret INTERNAL_TOKEN
GITEA_LFS_JWT_SECRET=  # gitea generate secret LFS_JWT_SECRET

# ── PAPERCLIP ────────────────────────────────────────────────
PAPERCLIP_ADMIN_EMAIL=admin@paperclip.local
PAPERCLIP_ADMIN_PASSWORD=  # choose a strong password
BETTER_AUTH_SECRET=  # openssl rand -hex 32
PAPERCLIP_AGENT_JWT_SECRET=  # openssl rand -hex 32

# ── SIYUAN ───────────────────────────────────────────────────
SIYUAN_TOKEN=  # from SiYuan Settings > API Token

# ── ANTHROPIC (for Mem0 LLM — optional if using Ollama) ─────
ANTHROPIC_API_KEY=  # sk-ant-... (only if Mem0 uses Anthropic)

# ── N8N ──────────────────────────────────────────────────────
N8N_AGENT_KEY=  # openssl rand -hex 16

# ── FIRECRAWL ────────────────────────────────────────────────
FIRECRAWL_BULL_KEY=firecrawl_admin
