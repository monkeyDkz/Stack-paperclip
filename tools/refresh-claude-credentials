#!/bin/bash
# ============================================================
# REFRESH CLAUDE CREDENTIALS
# Extrait le token depuis le keychain macOS → ~/.claude-config/
# Bind-mounted dans le container paperclip (pas de docker cp)
# Planifié via LaunchAgent toutes les 2 heures
# ============================================================

set -euo pipefail

CREDS_DIR="$HOME/.claude-config"
CREDS_FILE="$CREDS_DIR/.credentials.json"
LOG_FILE="/tmp/claude-credentials-refresh.log"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"; }

log "Refresh credentials..."

# Extraire depuis le keychain macOS
CREDS=$(security find-generic-password -s "Claude Code-credentials" -g 2>&1 \
    | grep "^password:" \
    | sed 's/^password: "//' \
    | sed 's/"$//')

if [ -z "$CREDS" ]; then
    log "ERREUR : credentials introuvables dans le keychain (claude auth login requis)"
    exit 1
fi

# Valider le JSON
echo "$CREDS" | python3 -m json.tool > /dev/null 2>&1 || {
    log "ERREUR : JSON invalide depuis le keychain"
    exit 1
}

# Extraire la date d'expiration pour le log
EXPIRES=$(echo "$CREDS" | python3 -c "
import sys, json, datetime
d = json.load(sys.stdin)
exp = d['claudeAiOauth']['expiresAt'] / 1000
print(datetime.datetime.fromtimestamp(exp).strftime('%Y-%m-%d %H:%M:%S'))
" 2>/dev/null || echo "?")

# Vérifier que le token n'est pas déjà expiré
IS_VALID=$(echo "$CREDS" | python3 -c "
import sys, json, time
d = json.load(sys.stdin)
exp = d['claudeAiOauth']['expiresAt'] / 1000
print('valid' if exp > time.time() else 'expired')
" 2>/dev/null || echo "unknown")

if [ "$IS_VALID" = "expired" ]; then
    log "WARN : token keychain déjà expiré ($EXPIRES) — lance 'claude auth login' pour renouveler"
    exit 1
fi

# Écrire directement dans le dossier bind-mounted
mkdir -p "$CREDS_DIR"
echo "$CREDS" > "$CREDS_FILE"
chmod 600 "$CREDS_FILE"

# Garder une copie dans /tmp pour debug
echo "$CREDS" > /tmp/claude-credentials.json

log "OK — token écrit dans $CREDS_FILE (expire le $EXPIRES)"
